{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "@dripleaf/item": ["../item/src/index.ts"],
      "@dripleaf/recipe": ["../recipe/src/index.ts"],
      "@dripleaf/chat": ["../chat/src/index.ts"],
      "@dripleaf/block": ["../block/src/index.ts"],
      "@dripleaf/entity": ["../entity/src/index.ts"],
      "@dripleaf/inventory": ["../inventory/src/index.ts"],
      "@dripleaf/protocol": ["../protocol/src/index.ts"],
      "@dripleaf/world": ["../world/src/index.ts"],
      "@dripleaf/core": ["../core/src/index.ts"],
      "@dripleaf/registry": ["../registry/src/index.ts"]
    }
  }
}
